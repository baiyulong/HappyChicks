<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:keepScreenOn="true">

    <!-- Egg counter — fixed in top-right corner -->
    <TextView
        android:id="@+id/egg_counter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="24dp"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/primary_dark"
        android:text="🥚 0" />

    <!-- Egg that pops up briefly at the chick's old position -->
    <ImageView
        android:id="@+id/egg"
        android:layout_width="70dp"
        android:layout_height="90dp"
        android:src="@drawable/ic_egg"
        android:visibility="gone"
        android:contentDescription="@null" />

    <!-- The chick — positioned dynamically; tap to lay an egg -->
    <ImageView
        android:id="@+id/chick"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:src="@drawable/ic_chick"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@null" />

</FrameLayout>
