<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_card_focused" />
            <corners android:radius="@dimen/card_corner" />
            <stroke android:width="@dimen/focus_stroke_width" android:color="@color/primary_dark" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bg_card" />
            <corners android:radius="@dimen/card_corner" />
            <stroke android:width="2dp" android:color="@color/text_secondary" />
        </shape>
    </item>
</selector>
